---
import MainLayout from '../layouts/MainLayout.astro';

const publications = [
  {
    "year": 2026,
    "items": [
      {
        "title": "Automated vehicle platooning systems and associated methods",
        "authors": "S Gopalswamy, M Ashley, D Franklin",
        "journal": "US Patent 12518633",
        "links": { "patent": "https://patents.google.com/patent/US12518633B2/en" }
      }
    ]
  },
  {
    "year": 2024,
    "items": [
      {
        "title": "Using a Sensor-Health-Aware Resilient Fusion for Localization in the Presence of GPS Spoofing Attacks",
        "authors": "S Moosavi, I Moore, S Gopalswamy",
        "journal": "2024 IEEE International Conference on Cyber Security and Resilience (CSR)",
        "links": { "paper": "https://ieeexplore.ieee.org/abstract/document/10679455"}
      },
      {
        "title": "Sensor-Health Aware Resilient Fusion With Application to Multi-Vehicle Tracking Using Infrastructure Sensors and Edge Compute",
        "authors": "S Moosavi, A Weaver, S Gopalswamy",
        "journal": "IEEE Transactions on Intelligent Transportation Systems 25 (11), 16059-16071",
        "links": { "paper": "https://ieeexplore.ieee.org/abstract/document/10556725" }
      }
    ]
  },
  {
    "year": 2023,
    "items": [
      {
        "title": "Unifying ontological framework for all-terrain datasets",
        "authors": "A Bhamri, A Medellin, D Grabowsky, D Mikulski, R Langari, ...",
        "journal": "2023 Seventh IEEE International Conference on Robotic Computing (IRC), 292-296",
        "links": { "paper": "https://ieeexplore.ieee.org/abstract/document/10473580" }
      },
      {
        "title": "Real-time semantic segmentation using hyperspectral images for unstructured and unknown environments",
        "authors": "A Medellin, A Bhamri, R Langari, S Gopalswamy",
        "journal": "2023 13th Workshop on Hyperspectral Imaging and Signal Processing",
        "links": { "paper": "https://ieeexplore.ieee.org/abstract/document/10431091" }
      },
      {
        "title": "Emergent Cooperative Behavior in Distributed Target Tracking with Unknown Occlusions",
        "authors": "T Li, LW Krakow, S Gopalswamy",
        "journal": "2023 IEEE/RSJ International Conference on Intelligent Robots and Systems",
        "links": { "paper": "https://ieeexplore.ieee.org/abstract/document/10342357" }
      },
      {
        "title": "Applications of unifying off-road datasets through ontology",
        "authors": "A Medellin, A Bhamri, A Ma, R Langari, S Gopalswamy, D Grabowsky, ...",
        "journal": "2024 NDIA Michigan Chapter Ground Vehicle Systems Engineering and Technology",
        "links": { "paper": "https://saemobilus.sae.org/papers/applications-unifying-off-road-datasets-through-ontology-2024-01-4074" }
      },
      {
        "title": "PHYSICALLY COOPERATING AUTONOMOUS GROUND VEHICLES",
        "authors": "M Ashley, D McMullan, S Gopalswamy",
        "journal": "2023 NDIA Michigan Chapter Ground Vehicle Systems Engineering and Technology",
        "links": { "paper": "https://scholar.google.com/citations?view_op=view_citation&hl=en&user=PWmUzp0AAAAJ&sortby=pubdate&citation_for_view=PWmUzp0AAAAJ:BqipwSGYUEgC" }
      },
      {
        "title": "Localization in Global Positioning System–Denied Environments Using Infrastructure-Embedded Analog-Digital Information",
        "authors": "S Moosavi",
        "journal": "SAE International Journal of Connected and Automated Vehicles 6 (4), 447-458",
        "links": { "paper": "https://saemobilus.sae.org/articles/localization-global-positioning-system-denied-environments-using-infrastructure-embedded-analog-digital-information-12-06-04-0029" }
      },
      {
        "title": "Real-time semantic segmentation using hyperspectral images for mapping unstructured and unknown environments",
        "authors": "A Medellin, A Bhamri, R Langari, S Gopalswamy",
        "journal": "arXiv preprint arXiv:2303.15623",
        "links": { "paper": "https://arxiv.org/abs/2303.15623" }
      },
      {
        "title": "PHYSICALLY COOPERATING AUTONOMOUS GROUND VEHICLES",
        "authors": "S Ashley, M., McMullan, D., and Gopalswamy",
        "journal": "SAE Technical Paper",
        "links": { "paper": "https://scholar.google.com/citations?view_op=view_citation&hl=en&user=PWmUzp0AAAAJ&sortby=pubdate&citation_for_view=PWmUzp0AAAAJ:vV6vV6tmYwMC" }
      },
      {
        "title": "Semantic world model for off-road environments for autonomous navigation and decision making",
        "authors": "A Bhamri, S Gopalswamy",
        "journal": "2nd International Workshop on Working towards Ontology-based Standards",
        "links": { "paper": "https://wosra.github.io/wosra2023/documents/WOSRA_2023_paper_3.pdf" }
      }
    ]
  }
];
---

<MainLayout title="Publications">
  <div class="publications-page container">
    <header class="page-header">
      <h1>Selected Publications</h1>
      <p>Full publications list on <u><a href="https://scholar.google.com/citations?hl=en&user=PWmUzp0AAAAJ&view_op=list_works&sortby=pubdate" target="_blank" rel="noopener"> Google Scholar</a></u></p>
      
      {/* Search and Filter Tools */}
      <div class="pub-tools">
        <div class="filter-dropdown">
          <label for="year-filter">Sort By:</label>
          <select id="year-filter" class="custom-select">
            <option value="newest">Newest First (Year)</option>
            <option value="oldest">Oldest First (Year)</option>
          </select>
        </div>
    </header>

    <div class="publications-list">
      {publications.map((yearGroup, yearIndex) => {
        return (
          <>
            <div class="year-group">
              <div class="year-heading">
                <h2>{yearGroup.year}</h2>
              </div>
              
              <div class="year-items">
                {yearGroup.items.map((pub, pubIndex) => {
                  return (
                    <div class="pub-entry">
                      <h3 class="pub-title">{pub.title}</h3>
                      <p class="pub-authors">{pub.authors}</p>
                      <p class="pub-journal"><em>{pub.journal}</em></p>
                      
                      <div class="pub-links">
                        {pub.links.pdf ? <a href={pub.links.pdf} class="btn-small bg-maroon">PDF</a> : null}
                        {pub.links.patent ? <a href={pub.links.patent} class="btn-small bg-secondary-maroon">Patent</a> : null}
                        {pub.links.paper ? <a href={pub.links.paper} class="btn-small bg-maroon">Paper</a> : null}

                      </div>

                      {/* Technical/gear icon separator, unless it's the last item in the list */}
                      {pubIndex < yearGroup.items.length - 1 ? (
                        <div class="pub-separator">
                          <span class="gear-icon">⚙️</span>
                        </div>
                      ) : null}
                    </div>
                  );
                })}
              </div>
            </div>
            
            {/* Major section divider, unless it's the very last year */}
            {yearIndex < publications.length - 1 ? (
              <hr class="year-divider" />
            ) : null}
          </>
        );
      })}
    </div>
  </div>
</MainLayout>

  <script type="module">
    const select = document.getElementById('year-filter');
    const list = document.querySelector('.publications-list');

    function rebuildDividers(groups) {
      const existingDividers = list.querySelectorAll('.year-divider');
      existingDividers.forEach(d => d.remove());
      groups.forEach((g, idx) => {
        if (idx < groups.length - 1) {
          const hr = document.createElement('hr');
          hr.className = 'year-divider';
          // Insert divider after this group (i.e. before the next group's element)
          list.insertBefore(hr, groups[idx + 1]);
        }
      });
    }

    if (select && list) {
      select.addEventListener('change', (e) => {
        const val = e.target.value;
        const groups = Array.from(list.querySelectorAll('.year-group'));

        groups.sort((a, b) => {
          const ay = parseInt(a.querySelector('.year-heading h2').textContent, 10) || 0;
          const by = parseInt(b.querySelector('.year-heading h2').textContent, 10) || 0;
          return val === 'newest' ? by - ay : ay - by;
        });

        // Append in new order
        groups.forEach(g => list.appendChild(g));

        // Rebuild dividers between groups
        rebuildDividers(groups);
      });
    }
  </script>

<style>
  .publications-page {
    padding: var(--spacing-xl) var(--spacing-md);
  }

  .page-header {
    margin-bottom: var(--spacing-xl);
  }

  .page-header h1 {
    font-size: 2.5rem;
    color: var(--primary-maroon);
    border-bottom: 3px solid var(--secondary-maroon);
    padding-bottom: var(--spacing-sm);
    display: inline-block;
  }

  /* Toolbar */
  .pub-tools {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    margin-top: var(--spacing-xs);
    margin-bottom: var(--spacing-xs);
    flex-wrap: wrap;
    gap: var(--spacing-md);
  }
  
  .custom-select {
    padding: 0.5rem;
    font-family: var(--font-body);
    font-size: 1rem;
    border: 1px solid #ccc;
    border-radius: 4px;
    margin-left: 0.5rem;
  }

  .search-bar {
    display: flex;
    border: 1px solid #ccc;
    border-radius: 4px;
    overflow: hidden;
  }

  .search-bar input {
    padding: 0.5rem 1rem;
    border: none;
    outline: none;
    font-family: var(--font-body);
    font-size: 1rem;
    min-width: 250px;
  }

  .search-btn {
    background-color: var(--light-gray);
    border: none;
    padding: 0 1rem;
    cursor: pointer;
    transition: background-color var(--transition-fast);
  }

  .search-btn:hover {
    background-color: #ddd;
  }

  /* List Layout */
  .year-group {
    display: flex;
    gap: var(--spacing-xl);
    margin-bottom: var(--spacing-lg);
  }

  .year-heading {
    flex: 0 0 150px;
  }

  .year-heading h2 {
    font-size: 3rem;
    color: var(--primary-maroon);
    margin: 0;
    position: sticky;
    top: 100px; /* Sticks when scrolling if desired */
  }

  .year-items {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .pub-entry {
    background-color: var(--white);
    padding: var(--spacing-lg) 0;
  }

  .pub-title {
    color: var(--primary-maroon);
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
    text-transform: none;
    font-family: var(--font-body);
    font-weight: 600;
  }

  .pub-authors {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }

  .pub-journal {
    color: var(--dark-gray);
    margin-bottom: 1rem;
  }

  .pub-links {
    display: flex;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-lg);
  }

  .btn-small {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    color: var(--white);
    text-decoration: none;
    font-family: var(--font-heading);
    font-size: 0.9rem;
    border-radius: 4px;
    border: none;
    cursor: pointer;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }
  
  .btn-small:hover {
    transform: translateY(-2px);
    opacity: 0.9;
    color: var(--white);
  }

  .bg-primary-maroon { background-color: var(--primary-maroon); }
  .bg-secondary-maroon { background-color: var(--secondary-maroon); }

  /* Separators */
  .pub-separator {
    text-align: center;
    margin-top: var(--spacing-lg);
    position: relative;
  }
  
  .pub-separator::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: rgba(0,0,0,0.1);
    z-index: 0;
  }

  .gear-icon {
    font-size: 1.5rem;
    background-color: var(--white);
    padding: 0 1rem;
    position: relative;
    z-index: 1;
    color: var(--secondary-maroon);
    opacity: 0.5;
  }

  .year-divider {
    border: 0;
    height: 3px;
    background-color: var(--primary-maroon);
    margin: var(--spacing-xl) 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .year-group {
      flex-direction: column;
      gap: var(--spacing-md);
    }

    .year-heading {
      flex: 0 0 auto;
    }

    .year-heading h2 {
      font-size: 2.5rem;
      border-bottom: 2px solid var(--secondary-maroon);
      padding-bottom: 0.5rem;
      position: static;
    }

    .search-bar input {
      min-width: auto;
      width: 100%;
    }
  }

  /* Subtle entry reveals and interactions */
  .pub-entry { opacity: 0; transform: translateX(-12px); animation: slideInLeft 0.6s ease-out forwards; }
  .year-items .pub-entry:nth-child(1) { animation-delay: 0.12s; }
  .year-items .pub-entry:nth-child(2) { animation-delay: 0.18s; }
  .year-items .pub-entry:nth-child(n+3) { animation-delay: 0.24s; }

  .gear-icon { transition: transform var(--transition-normal); }
  .pub-separator:hover .gear-icon { transform: rotate(180deg); }

  .btn-small { transition: transform var(--transition-fast), opacity var(--transition-fast), box-shadow var(--transition-fast); }
  .btn-small:hover { box-shadow: 0 8px 20px rgba(0,0,0,0.12); }
</style>
