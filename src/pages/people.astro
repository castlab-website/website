---
import MainLayout from '../layouts/MainLayout.astro';
import MemberCard from '../components/MemberCard.astro';

const teamMembers = {
  director: [
    {
      name: 'Dr. Swami Gopalswamy',
      title: 'Lab Director',
      bio: 'Text',
      imageSrc: '/img/tempheadshot.jpg'
    }
  ],
  postdocs: [
    {
      name: 'Dr. Ajinkya Joglekar',
      title: 'Postdoctoral Researcher',
      bio: 'Text',
      imageSrc: '/img/tempheadshot.jpg'
    }
  ],
  graduate: [
    {
      name: 'Name',
      title: 'PhD Student',
      bio: 'Text',
      imageSrc: '/img/tempheadshot.jpg'
    },
    {
      name: 'Name',
      title: 'Masters Student',
      bio: 'Text',
      imageSrc: '/img/tempheadshot.jpg'
    }
  ],
  undergraduate: [
    {
      name: 'Name',
      title: 'Undergraduate Researcher',
      bio: 'Text',
      imageSrc: '/img/tempheadshot.jpg'
    }
  ]
};
---

<MainLayout title="People">
  <div class="people-page container">
    
    <div class="intro-section bg-light-section">
      <div class="page-title">
        <h1>Meet the CAST Team</h1>
      </div>
      <header class="team-header">
        <img src="/img/groupphoto.JPG" alt="CAST Lab Team" class="pano-img" onerror="this.src='/home-truck-placeholder.jpg'" />
      </header>
    </div>

    <div class="team-sections">
      
      <section class="role-section">
        <h2>Lab Director</h2>
        <div class="members-list">
          {teamMembers.director.map(member => (
            <MemberCard {...member} />
          ))}
        </div>
      </section>

      <section class="role-section bg-light-section">
        <h2>Postdoctoral Researchers</h2>
        <div class="members-list">
          {teamMembers.postdocs.map(member => (
            <MemberCard {...member} />
          ))}
        </div>
      </section>

      <section class="role-section">
        <h2>Graduate Students</h2>
        <div class="members-list">
          {teamMembers.graduate.map(member => (
            <MemberCard {...member} />
          ))}
        </div>
      </section>

      <section class="role-section bg-light-section">
        <h2>Undergraduate Students</h2>
        <div class="members-list">
          {teamMembers.undergraduate.map(member => (
            <MemberCard {...member} />
          ))}
        </div>
      </section>

    </div>
  </div>
</MainLayout>

<style>
  .people-page {
    padding: 0 0 var(--spacing-xl) 0;
  }

  .team-header {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    margin: 0 5% 0; /* Force spacing on sides */
    border: 4px solid var(--secondary-maroon);
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  }

  .pano-img {
    width: 100%;
    height: 350px;
    object-fit: cover; /* Panoramic effect */
    display: block;
    filter: brightness(1);
  }

  .page-title {
    text-align: center;
    margin-bottom: var(--spacing-lg);
  }

  .page-title h1 {
    color: var(--primary-maroon);
    font-size: 3.5rem;
    margin: 0;
    text-transform: uppercase;
    font-family: var(--font-heading);
  }

  /* Team Sections Layout */
  .team-sections {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xl);
  }

  .role-section {
    padding: var(--spacing-lg) 0;
  }

  .bg-light-section {
    /* Slight background alternating for visual break */
    background-color: var(--light-gray);
    margin: 0 calc(-50vw + 50%); /* Full bleed trick */
    padding: var(--spacing-xl) calc(50vw - 50%);
  }

  .role-section h2 {
    text-align: center;
    font-size: 2.25rem;
    color: var(--primary-maroon);
    margin-bottom: var(--spacing-lg);
    font-family: var(--font-heading);
    position: relative;
    display: inline-block;
    left: 50%;
    transform: translateX(-50%);
  }
  
  .role-section h2::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 25%;
    width: 50%;
    height: 3px;
    background-color: var(--secondary-maroon);
  }

  .members-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  @media (max-width: 768px) {
    .pano-img {
      height: 200px;
    }
    
    .page-title h1 {
      font-size: 2rem;
    }
    
    .role-section h2 {
      font-size: 1.8rem;
    }
  }
</style>
