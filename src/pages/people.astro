---
import MainLayout from '../layouts/MainLayout.astro';
import MemberCard from '../components/MemberCard.astro';

const teamMembers = {
  director: [
    {
      name: 'Dr. Swaminathan Gopalswamy',
      title: 'Lab Director',
      bio: 'Bio Text Here',
      imageSrc: '/img/gopalswamy.jpg'
    }
  ],
  postdocs: [
    {
      name: 'Dr. Ajinkya Joglekar',
      title: 'Senior Research Engineer',
      bio: 'Text',
      imageSrc: '/img/tempheadshot.jpg'
    }
  ],
  graduate: [
    {
      name: 'Michiel "Mike" Ashley',
      title: 'PhD Candidate',
      bio: 'Michiel (Mike) Ashley is a Mechanical Engineering Ph.D. candidate who joined the Connected Autonomous Safe Technologies (CAST) Laboratory in 2020. His doctoral research is intensely focused on the Hard Platooning project, where he designs and implements physical coordination frameworks and control algorithms for autonomous ground vehicles. Leveraging the deep theoretical and technical expertise cultivated during his Ph.D., Mike founded a technology startup in the same space to deploy advanced platooning systems for the Department of War (DoW) and commercial sectors. His academic contributions to the field include the co-authored papers "Physically Cooperating Autonomous Ground Vehicles" presented at GVSETS (2023) and "Application of Nonlinear Control for Hard Truck Platooning" presented at IEEE ICCVE (2022). Furthermore, his innovative approach to vehicle coordination during his academic tenure resulted in the issuance of US Patent 12,518,633, secured through the Texas A&M University system. Outside of his rigorous academic and professional commitments, Mike is a passionate automotive mechanic and enjoys taking extended motorcycle trips.',
      imageSrc: '/img/mikeashley.png'
    },
    {
      name: 'Yash Raj Sharma',
      title: 'PhD Student',
      bio: 'Bio Text Here',
      imageSrc: '/img/yashsharma.JPG'
    },
    {
      name: 'Yi Ling Wu',
      title: 'PhD Student',
      bio: 'Bio Text Here',
      imageSrc: '/img/tempheadshot.jpg'
    },
    {
      name: 'Atharva Pravin Bilgi',
      title: 'Masters Student',
      bio: 'Atharva Pravin Bilgi is a Mechanical Engineering, M.S. Thesis candidate who joined CAST Laboratory in 2025. His research is focused on developing control algorithms, autonomy algorithms and model based systems engineering for ground vehicles.',
      imageSrc: '/img/atharvabilgi.jpg'
    },
    {
      name: 'Matthew Hancock',
      title: 'Masters Student',
      bio: 'Matthew Hancock is a Mechanical Engineering Master of Science student with a research focus on autonomous ground vehicle control systems. He joined the Connected Autonomous Safe Technologies (CAST) Laboratory as an undergraduate in 2022, assisting Mike Ashley with his Ph.D. research on Hard Platooning, which has now become the focus of his own graduate research. Matthew has also made contributions to the Physically Cooperating Robots (PCR) research project in the CAST Lab, designing and simulating the hydraulic system to actuate a robotic arm for inter-vehicle linking. In 2024, Matthew was selected for the Los Alamos Dynamics Summer School (LADSS) at Los Alamos National Laboratory. During the program, he investigated nonlinear vibration damping methods and co-authored "Design of a Tuned Vibration Absorber with Friction Contact for High Location Ratio Application," which was presented at the 2025 IMAC Conference. In addition to his academic pursuits, Matthew has served for over 6 years as an Engineer Equipment Mechanic (1341) in the United States Marine Corps Reserve.',
      imageSrc: '/img/matthewhancock.jpg'
    },
    {
      name: 'Diego Macias',
      title: 'Masters Student',
      bio: 'Bio Text Here',
      imageSrc: '/img/tempheadshot.jpg'
    },
    {
      name: 'Jordan Runyan',
      title: 'Masters Student',
      bio: 'Bio Text Here',
      imageSrc: '/img/tempheadshot.jpg'
    }
  ],
  undergraduate: [
    {
      name: 'Justin Simms',
      title: 'Undergraduate Student',
      bio: 'Bio Text Here',
      imageSrc: '/img/tempheadshot.jpg'
    },
    {
      name: 'Hayden Sadd',
      title: 'Undergraduate Student',
      bio: 'Bio Text Here',
      imageSrc: '/img/tempheadshot.jpg'
    }
  ]
};
---

<MainLayout title="People">
  <div class="people-page container">
    
    <div class="intro-section bg-light-section">
      <div class="page-title">
        <h1>Meet the CAST Team</h1>
      </div>
      <header class="team-header">
        <img src="/img/groupphoto.JPG" alt="CAST Lab Team" class="pano-img" onerror="this.src='/home-truck-placeholder.jpg'" />
      </header>
    </div>

    <div class="team-sections">
      
      <section class="role-section">
        <h2>Lab Director</h2>
        <div class="members-list">
          {teamMembers.director.map(member => (
            <MemberCard {...member} />
          ))}
        </div>
      </section>

      <section class="role-section bg-light-section">
        <h2>Postdoctoral Researchers</h2>
        <div class="members-list">
          {teamMembers.postdocs.map(member => (
            <MemberCard {...member} />
          ))}
        </div>
      </section>

      <section class="role-section">
        <h2>Graduate Students</h2>
        <div class="members-list">
          {teamMembers.graduate.map(member => (
            <MemberCard {...member} />
          ))}
        </div>
      </section>

      <section class="role-section bg-light-section">
        <h2>Undergraduate Students</h2>
        <div class="members-list">
          {teamMembers.undergraduate.map(member => (
            <MemberCard {...member} />
          ))}
        </div>
      </section>

    </div>
  </div>
</MainLayout>

<style>
  .people-page {
    padding: 0 0 var(--spacing-xl) 0;
  }

  .team-header {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    margin: 0 5% 0; /* Force spacing on sides */
    border: 4px solid var(--secondary-maroon);
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  }

  .pano-img {
    width: 100%;
    height: 350px;
    object-fit: cover; /* Panoramic effect */
    display: block;
    filter: brightness(1);
  }

  .page-title {
    text-align: center;
    margin-bottom: var(--spacing-lg);
  }

  .page-title h1 {
    color: var(--primary-maroon);
    font-size: 3.5rem;
    margin: 0;
    text-transform: uppercase;
    font-family: var(--font-heading);
  }

  /* Team Sections Layout */
  .team-sections {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xl);
  }

  .role-section {
    padding: var(--spacing-lg) 0;
  }

  .bg-light-section {
    /* Slight background alternating for visual break */
    background-color: var(--light-gray);
    margin: 0 calc(-50vw + 50%); /* Full bleed trick */
    padding: var(--spacing-xl) calc(50vw - 50%);
  }

  .role-section h2 {
    text-align: center;
    font-size: 2.25rem;
    color: var(--primary-maroon);
    margin-bottom: var(--spacing-lg);
    font-family: var(--font-heading);
    position: relative;
    display: inline-block;
    left: 50%;
    transform: translateX(-50%);
  }
  
  .role-section h2::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 25%;
    width: 50%;
    height: 3px;
    background-color: var(--secondary-maroon);
  }

  .members-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  @media (max-width: 768px) {
    .pano-img {
      height: 200px;
    }
    
    .page-title h1 {
      font-size: 2rem;
    }
    
    .role-section h2 {
      font-size: 1.8rem;
    }
  }

  /* Subtle page reveal animations */
  .page-title h1 { opacity: 0; transform: translateY(-12px); animation: slideDown 0.6s ease-out forwards; }
  .pano-img { opacity: 0; animation: fadeIn 0.8s ease-out 0.2s forwards; transition: filter var(--transition-normal); }
  .team-header:hover .pano-img { filter: brightness(1.06) contrast(1.03); }

  .members-list > * { opacity: 0; transform: translateY(12px); animation: slideUp 0.55s ease-out forwards; }
  .members-list > *:nth-child(1) { animation-delay: 0.12s; }
  .members-list > *:nth-child(2) { animation-delay: 0.18s; }
  .members-list > *:nth-child(3) { animation-delay: 0.24s; }
  .members-list > *:nth-child(4) { animation-delay: 0.30s; }
</style>
