---
import MainLayout from '../../layouts/MainLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

// Placeholder data for projects
const projects = [
  {
    id: 'hard-platooning',
    title: 'Hard Platooning',
    imageSrc: '/img/tempProject.jpg',
    description: 'Summary',
  },
  {
    id: 'Project1',
    title: 'Temp',
    imageSrc: '/img/tempProject.jpg',
    description: 'Summary',
  },
  {
    id: 'Project2',
    title: 'Temp',
    imageSrc: '/img/tempProject.jpg',
    description: 'Summary',
  },
  {
    id: 'Project3',
    title: 'Temp',
    imageSrc: '/img/tempProject.jpg',
    description: 'Summary',
  },
  {
    id: 'Project4',
    title: 'Temp',
    imageSrc: '/img/tempProject.jpg',
    description: 'Summary',
  },
];
---

<MainLayout title="Research Projects">
  <div class="container research-page">
    <header class="page-header">
      <h1>Our Research Projects !</h1>
    </header>

    <div class="projects-grid">
      {projects.map((project) => (
        <ProjectCard 
          title={project.title}
          imageSrc={project.imageSrc}
          description={project.description}
          link={`/research/${project.id}`}
        />
      ))}
    </div>
  </div>
</MainLayout>

<style>
  .research-page {
    padding: var(--spacing-xl) var(--spacing-md);
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }

  .page-header h1 {
    font-size: 3rem;
    color: var(--primary-maroon);
    font-family: var(--font-heading);
    text-transform: none; 
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
  }

  @media (max-width: 992px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
