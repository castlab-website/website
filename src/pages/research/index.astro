---
import MainLayout from '../../layouts/MainLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = [
  {
    id: 'hard-platooning',
    title: 'Hard Platooning',
    imageSrc: '/img/hardplatooning.png',
    description: 'A novel vehicle platooning technology in which multiple vehicles are physically linked using a product called the Hard Connect',
  },
  {
    id: 'phev',
    title: 'Parallel Hybrid Electric Vehicle (PHEV) Modeling & Simulation',
    imageSrc: '/img/tempProject.jpg',
    description: 'A comprehensive physics-based simulation model of a 12-ton parallel hybrid electric truck developed in MATLAB/Simulink',
  },
  {
    id: 'semantic-world-models',
    title: 'Semantic World Models for Reasoning and Decision-Making in Uncertain Environments',
    imageSrc: '/img/tempProject.jpg',
    description: 'Advancing semantic mapping by using conventional artificial intelligence approaches with domain knowledge to model complex environments more effectively',
  },
  {
    id: 'autonomous-navigation-stack',
    title: 'Sim-to-Real Autonomous Navigation Stack for Drive-By-Wire Vehicles',
    imageSrc: '/img/navstack.png',
    description: 'Developing a full-stack autonomous navigation on a Lincoln MKZ platform',
  },
  {
    id: 'castbot-gamma',
    title: 'CASTBot Gamma',
    imageSrc: '/img/castbotgamma.jpg',
    description: 'Designing a compact, hypermobile robot capable of traversing diverse environments and overcome obstacles such as stairs, gaps, and debris',
  },
];

const filteredProjects = projects;
---

<MainLayout title="Research Projects">
  <!-- Hero -->
  <section class="hero bg-secondary-red">
    <div class="container hero-inner">
      <h1 class="hero-title text-center fade-in">OUR RESEARCH PROJECTS</h1>
      <p class="hero-sub text-center fade-in">Our vision is to advance technology that enhances human safety and security through the strategic integration of connectivity and autonomy. We focus on addressing fundamental research questions in the analysis, optimal design, and functional verification of large-scale, multidisciplinary systems.</p>
      
    </div>
  </section>

  <!-- Projects grid -->
  <div class="container" style="padding: var(--spacing-xl) 0;">
    <div class="projects-grid">
      {filteredProjects.map((project) => (
        <ProjectCard
          title={project.title}
          imageSrc={project.imageSrc}
          description={project.description}
          link={`/research/${project.id}`}
        />
      ))}
    </div>
  </div>

  <!-- Collaborate CTA -->
  <section class="collab">
    <div class="container">
      <h2>INTERESTED IN COLLABORATING?</h2>
      <p>Temp text</p>
      <!-- <div style="margin-top: var(--spacing-md);"><a class="btn" href="/contact">CONTACT OUR LAB</a></div> -->
    </div>
  </section>
</MainLayout>

<style>
  .hero-inner { padding: var(--spacing-xl) 0; display: flex; flex-direction: column; align-items: center; text-align: center; }
  .hero-title { letter-spacing: 2px; color: white; margin: 0; }
  .hero-sub { margin-top: var(--spacing-md); color: white; max-width: 90ch; font-size: 15px;}

  /* Page load timing to match other pages' hero animation */
  .hero-title.fade-in { animation-delay: 0.08s; }
  .hero-sub.fade-in { animation-delay: 0.16s; }
  h2 { text-transform: uppercase; }
</style>
