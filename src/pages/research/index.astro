---
import MainLayout from '../../layouts/MainLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

// Placeholder data for projects
const projects = [
  {
    id: 'hard-platooning',
    title: 'Hard Platooning',
    imageSrc: '/img/tempProject.jpg',
    description: 'Summary',
  },
  {
    id: 'Project1',
    title: 'Temp',
    imageSrc: '/img/tempProject.jpg',
    description: 'Summary',
  },
  {
    id: 'Project2',
    title: 'Temp',
    imageSrc: '/img/tempProject.jpg',
    description: 'Summary',
  },
  {
    id: 'Project3',
    title: 'Temp',
    imageSrc: '/img/tempProject.jpg',
    description: 'Summary',
  },
  {
    id: 'Project4',
    title: 'Temp',
    imageSrc: '/img/tempProject.jpg',
    description: 'Summary',
  },
];
---

<MainLayout title="Research Projects">
  <div class="container research-page">
    <header class="page-header">
      <h1>Our Research Projects !</h1>
    </header>

    <div class="projects-grid">
      {projects.map((project) => (
        <ProjectCard 
          title={project.title}
          imageSrc={project.imageSrc}
          description={project.description}
          link={`/research/${project.id}`}
        />
      ))}
    </div>
  </div>
</MainLayout>

<style>
  .research-page {
    padding: var(--spacing-xl) var(--spacing-md);
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }

  .page-header h1 {
    font-size: 3rem;
    color: var(--primary-maroon);
    font-family: var(--font-heading);
    text-transform: none; 
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
  }

  @media (max-width: 992px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Staggered project reveal */
  .projects-grid > * { opacity: 0; transform: translateY(12px); animation: slideUp 0.55s ease-out forwards; }
  .projects-grid > *:nth-child(1) { animation-delay: 0.08s; }
  .projects-grid > *:nth-child(2) { animation-delay: 0.14s; }
  .projects-grid > *:nth-child(3) { animation-delay: 0.20s; }
  .projects-grid > *:nth-child(4) { animation-delay: 0.26s; }
  .projects-grid > *:nth-child(5) { animation-delay: 0.32s; }

  .page-header h1 { position: relative; display: inline-block; }
  .page-header h1::after { content: ''; position: absolute; left: 0; bottom: -10px; width: 0; height: 4px; background: var(--primary-maroon); transition: width 0.8s ease-out; }
  .page-header h1 { animation: fadeIn 0.6s ease-out forwards; }
  .page-header h1[style]::after, .page-header h1 { width: auto; }
</style>
