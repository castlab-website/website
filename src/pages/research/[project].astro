---
import MainLayout from '../../layouts/MainLayout.astro';

export function getStaticPaths() {
  return [
    {params: {project: 'hard-platooning'}},
    {params: {project: 'Project1'}},
    {params: {project: 'Project2'}},
    {params: {project: 'Project3'}},
    {params: {project: 'Project4'}},
  ];
}

const { project } = Astro.params;

const projectsDB: Record<string, any> = {
  'hard-platooning': {
    title: 'Hard Platooning',
    imageSrc: '/img/tempProject.jpg',
    whatIsIt: 'Text',
    whyNeeded: 'Text',
    whatCastIsDoing: 'Text',
    publications: [],
    topic: 'Topic B'
  },
  'Project1': {
    title: 'Project',
    imageSrc: '/img/tempProject.jpg',
    whatIsIt: 'text',
    whyNeeded: 'text',
    whatCastIsDoing: 'text',
    publications: [],
    topic: 'Topic A'
  },
  'Project2': {
    title: 'Project',
    imageSrc: '/img/tempProject.jpg',
    whatIsIt: 'text',
    whyNeeded: 'text',
    whatCastIsDoing: 'text',
    publications: [],
    topic: 'Topic B'
  },
  'Project3': {
    title: 'Project',
    imageSrc: '/img/tempProject.jpg',
    whatIsIt: 'text',
    whyNeeded: 'text',
    whatCastIsDoing: 'text',
    publications: [],
    topic: 'Topic C'
  },
  'Project4': {
    title: 'Project',
    imageSrc: '/img/tempProject.jpg',
    whatIsIt: 'text',
    whyNeeded: 'text',
    whatCastIsDoing: 'text',
    publications: [],
    topic: 'Topic A'
  }
};

const projectData = projectsDB[project as string] || projectsDB['hard-platooning'];
---

<MainLayout title={projectData.title}>
  <div class="container project-detail-page">
    
    <header class="project-header">
      <img src={projectData.imageSrc} alt={projectData.title} class="header-image" onerror="this.src='/img/tempProject.jpg'" />
      <div class="header-title-box">
        <h1>{projectData.title}</h1>
      </div>
    </header>

    <div class="content-sections">
      
      {/* "What is it?" Section */}
      <section class="info-section">
        <div class="content-box bg-maroon chevron-box">
          <h2>What is it?</h2>
          <p>{projectData.whatIsIt}</p>
        </div>
        <div class="empty-space"></div>
      </section>

      {/* "Why is it needed?" Section */}
      <section class="info-section reverse-section">
        <div class="empty-space"></div>
        <div class="content-box bg-secondary-maroon reverse-chevron-box">
          <h2>Why is it needed?</h2>
          <p>{projectData.whyNeeded}</p>
        </div>
      </section>

      {/* "What is CAST lab doing to improve it?" Section */}
      <section class="info-section">
        <div class="content-box bg-maroon chevron-box">
          <h2>What is CAST lab doing to improve it?</h2>
          <p>{projectData.whatCastIsDoing}</p>
        </div>
        <div class="empty-space"></div>
      </section>

      {/* "Select Publications or Links" Section */}
      <section class="info-section reverse-section">
        <div class="empty-space"></div>
        <div class="content-box bg-secondary-maroon reverse-chevron-box">
          <h2>Select Publications & Links</h2>
          <ul class="publications-list">
            {projectData.publications.map(pub => (
              <li><a href={pub.link}>{pub.title}</a></li>
            ))}
          </ul>
        </div>
      </section>

    </div>
  </div>
</MainLayout>

<style>
  .project-detail-page {
    padding: var(--spacing-lg) 0 var(--spacing-xl) 0;
  }

  .project-header {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: var(--spacing-xl);
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    background-color: var(--light-gray);
  }

  .header-image {
    width: 100%;
    height: 400px;
    object-fit: cover;
    display: block;
  }

  .header-title-box {
    position: absolute;
    bottom: 0;
    left: 0;
    background-color: rgba(80, 0, 0, 0.9);
    padding: var(--spacing-md) var(--spacing-xl);
    border-top-right-radius: 16px;
  }

  .header-title-box h1 {
    color: var(--white);
    margin: 0;
    font-size: 2.5rem;
  }

  .content-sections {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .info-section {
    display: flex;
    align-items: center;
  }

  .info-section.reverse-section {
    /* For alternating layout if desired */
  }

  .content-box {
    flex: 0 0 95%;
    padding: var(--spacing-xl);
    color: var(--white);
    position: relative;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
  }

  .empty-space {
    flex: 0 0 5%;
  }

  .content-box h2 {
    color: var(--white);
    border-bottom: 2px solid rgba(255,255,255,0.3);
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
  }

  .content-box p {
    font-size: 1.1rem;
    line-height: 1.6;
    margin: 0;
  }

  .publications-list {
    list-style: none; /* Can be changed to disc if bullets are preferred */
    padding-left: 1.5rem;
    margin: 0;
  }
  
  .publications-list li {
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
    list-style-type: square;
  }
  
  .publications-list a {
    color: var(--white);
    text-decoration: underline;
  }
  .publications-list a:hover {
    color: var(--light-gray);
  }

  /* Chevron Cutout Effect using clip-path */
  .chevron-box {
    clip-path: polygon(0% 0%, 95% 0%, 100% 50%, 95% 100%, 0% 100%);
  }

  /* Reversed Chevron for variety */
  .reverse-chevron-box {
    clip-path: polygon(5% 0%, 100% 0%, 100% 100%, 5% 100%, 0% 50%);
  }
  
  .bg-secondary-maroon {
    background-color: var(--secondary-maroon);
  }

  @media (max-width: 768px) {
    .header-image {
      height: 250px;
    }
    
    .header-title-box h1 {
      font-size: 1.8rem;
    }

    .content-box {
      flex: 0 0 100%;
      clip-path: none; 
      border-radius: 8px;
    }
    
    .empty-space {
      display: none;
    }
  }
</style>
