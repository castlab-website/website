---
interface Props {
  name: string;
  title: string;
  bio: string;
  imageSrc?: string; // Optional image source
}

const { name, title, bio, imageSrc } = Astro.props;
---

<div class="member-card">
  <div class="photo-container">
    {imageSrc ? (
      <img src={imageSrc} alt={`${name}'s profile photo`} class="profile-photo" />
    ) : (
      <div class="photo-placeholder"></div>
    )}
  </div>
  <div class="info-container bg-maroon">
    <h3 class="name">{name}</h3>
    <p class="title">{title}</p>
    <p class="bio">{bio}</p>
  </div>
</div>

<style>
  .member-card {
    display: flex;
    flex-direction: row;
    width: 80%; /* Roughly 80% container width as spec'd */
    margin: 0 auto;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    background-color: var(--white);
  }

  /* Force stack on small screens */
  @media (max-width: 600px) {
    .member-card {
      flex-direction: column;
      width: 100%;
    }
  }

  .photo-container {
    flex: 0 0 250px; /* Fixed width for the photo container */
    background-color: var(--white); /* White placeholder */
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 600px) {
    .photo-container {
      flex: 0 0 auto;
      width: 100%;
      aspect-ratio: 1; /* Square photo placeholder */
    }
  }

  .profile-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .photo-placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--light-gray);
  }

  .info-container {
    flex: 1; /* Take up remaining space */
    padding: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: var(--white);
  }

  .name {
    margin-bottom: 0.25rem;
    font-size: 1.5rem;
  }

  .title {
    font-family: var(--font-heading);
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: var(--spacing-md);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 500;
  }

  .bio {
    line-height: 1.6;
    margin-bottom: 0;
  }
</style>
