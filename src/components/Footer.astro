---
const currentYear = new Date().getFullYear();
---

<footer class="global-footer bg-maroon">
  <div class="container footer-container">
    <div class="footer-primary">
      <h2 class="lab-title">CAST - Connected Autonomous Safe Technologies Laboratory @ Texas A&M University</h2>
    </div>
    
    <div class="footer-secondary">
      <div class="contact-info">
        <h3>Contact Us</h3>
        <p>1234 Engineering Building<br>College Station, TX 77843</p>
        <p><a href="mailto:contact@cast.tamu.edu">contact@cast.tamu.edu</a></p>
      </div>
      
      <div class="footer-links">
        <h3>Quick Links</h3>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/research/">Research</a></li>
          <li><a href="/people/">People</a></li>
          <li><a href="/publications/">Publications</a></li>
        </ul>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p>&copy; {currentYear} CAST Laboratory. All Rights Reserved.</p>
    </div>
  </div>
</footer>

<style>
  .global-footer {
    padding: var(--spacing-xl) 0 var(--spacing-md) 0;
    color: var(--white);
    margin-top: auto; /* Pushes footer to bottom if content is short */
  }

  .footer-container {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .lab-title {
    font-size: 2rem;
    max-width: 800px;
    margin-bottom: 0;
  }

  .footer-secondary {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--spacing-lg);
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    padding-top: var(--spacing-lg);
  }

  .contact-info h3, .footer-links h3 {
    font-size: 1.25rem;
    margin-bottom: var(--spacing-sm);
  }

  .contact-info p {
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .contact-info a {
    text-transform: none;
    text-decoration: underline;
  }

  .footer-links ul {
    list-style: none;
  }

  .footer-links li {
    margin-bottom: 0.5rem;
  }

  .footer-bottom {
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    padding-top: var(--spacing-md);
    font-size: 0.875rem;
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .lab-title {
      font-size: 1.5rem;
    }
    
    .footer-secondary {
      flex-direction: column;
    }
  }
</style>
