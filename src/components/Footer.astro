---
const currentYear = new Date().getFullYear();
---

<footer class="global-footer bg-maroon">
  <div class="container footer-container">
    <div class="footer-primary">
      <h2 class="lab-title">
      CAST - Connected Autonomous Safe Technologies Laboratory
      <span class="university-text">@ Texas A&M University</span>
    </h2>
    </div>
    
    <div class="footer-secondary">
      <div class="contact-info">
        <h3>Contact Us</h3>
        <p>Doherty Bldg #305<br>College Station, TX 77840</p>
        <p><a href="mailto:cast@insert.email.edu">cast@insert.email.edu</a></p>
      </div>
      
      <div class="footer-links">
        <h3>Quick Links</h3>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/research/">Research</a></li>
          <li><a href="/people/">People</a></li>
          <li><a href="/publications/">Publications</a></li>
        </ul>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p>&copy; {currentYear} CAST Laboratory. All Rights Reserved.</p>
    </div>
  </div>
</footer>

<style>
  .global-footer {
    padding: var(--spacing-xl) 0 var(--spacing-md) 0;
    color: var(--white);
    margin-top: auto; /* Pushes footer to bottom if content is short */
  }

  .footer-container {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .lab-title {
    font-size: 2rem;
    max-width: 100%;
    margin-bottom: 0;
  }

  .lab-title {
    opacity: 0;
    animation: slideInDown 0.6s ease-out forwards;
  }

  .university-text {
    font-size: 1.25rem;
    display: block;
    font-weight: normal; 
    margin-top: 0.5rem;
    /* font-family: 'Your-Alternate-Font', sans-serif; Optional: Use a different font for the university text */
  }

  .footer-secondary {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--spacing-lg);
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    padding-top: var(--spacing-lg);
  }

  .contact-info h3, .footer-links h3 {
    font-size: 1.25rem;
    margin-bottom: var(--spacing-sm);
  }

  .contact-info p {
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .contact-info a {
    text-transform: none;
    text-decoration: none;
    transition: background-color var(--transition-fast), color var(--transition-fast);
    position: relative;
    padding-bottom: 2px;
  }

  .contact-info a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 0;
    height: 2px;
    background: rgba(255,255,255,0.9);
    transition: width var(--transition-normal);
  }
  .contact-info a:hover::after { width: 100%; }
  .contact-info a:hover { color: var(--white); }

  .footer-links ul {
    list-style: none;
  }

  .footer-links li {
    margin-bottom: 0.5rem;
    margin-right: 5rem;
  }

  .footer-links a {
    color: var(--white);
    position: relative;
    transition: color var(--transition-fast);
  }

  .footer-links a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 0;
    height: 2px;
    background: var(--white);
    transition: width var(--transition-normal);
  }

  .footer-links a:hover::after { width: 100%; }

  .footer-bottom {
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    padding-top: var(--spacing-md);
    font-size: 0.875rem;
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .lab-title {
      font-size: 1.5rem;
    }
    
    .footer-secondary {
      flex-direction: column;
    }
  }
</style>
