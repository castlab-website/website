---
interface Props {
  title: string;
  imageSrc: string;
  description: string;
  link: string;
}

const { title, imageSrc, description, link } = Astro.props;
---

<a href={link} class="project-card">
  <div class="image-wrapper">
    <img src={imageSrc} alt={title} />
    <div class="overlay">
      <p>{description}</p>
    </div>
  </div>
  <div class="card-footer bg-maroon">
    <h3>{title}</h3>
  </div>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
    text-decoration: none;
    color: inherit;
    background-color: var(--white);
  }

  .project-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
  }

  .image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9; /* Or whatever ratio fits the design best */
    overflow: hidden;
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-normal), filter var(--transition-normal);
  }

  .overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(61, 0, 0, 0.85); /* Dark maroon overlay */
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-md);
    opacity: 0;
    transition: opacity var(--transition-normal);
  }

  .overlay p {
    color: var(--white);
    text-align: center;
    transform: translateY(20px);
    transition: transform var(--transition-normal);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  /* Specific Hover Effects requested in detail_spec.md */
  .project-card:hover .image-wrapper img {
    transform: scale(1.05); /* Enlarge slightly */
    filter: grayscale(100%); /* Gray out */
  }

  .project-card:hover .overlay {
    opacity: 1; /* Reveal descriptive text layered over image */
  }

  .project-card:hover .overlay p {
    transform: translateY(0);
  }

  .card-footer {
    padding: var(--spacing-md);
    text-align: center;
    flex-grow: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-footer h3 {
    margin-bottom: 0;
    font-size: 1.2rem;
    color: var(--white);
  }
</style>
